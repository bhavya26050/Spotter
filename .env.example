# Example environment configuration for Route Fuel Planner
# Copy to .env and modify as needed

# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# External API timeouts (seconds)
REQUEST_TIMEOUT_SECONDS=12

# Fuel price CSV location (relative to project root)
FUEL_PRICES_CSV=data/fuel_prices.csv

# External APIs used (read-only, for reference)
# OSRM_BASE_URL=https://router.project-osrm.org
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
